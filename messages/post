# cat apps/wireless/workers/Hal | sh post Boss Hal
#                       OR
# pass body to post with here document as shown below

usage="""
sh post Boss Hal <<EOF
Hello, Hal. I'm your boss.
What are you working on?
EOF
"""

body=$(cat)
jq -n --arg from "$1" --arg to "$2" --arg body "$body" '{from:$from, to:$to, body:$body}' |
curl -s -X POST "$MESSAGES_URL" -H "Content-Type: application/json" -d @- > /dev/null