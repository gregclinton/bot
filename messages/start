messages="https://raw.githubusercontent.com/gregclinton/bot/refs/heads/main/messages"

if [ -f messages.py ]; then
    # ---- edits here donls't require a docker build ----
    mkdir chat
    curl -s $messages/chat/chat.js -o chat/chat.js
    curl -s $messages/chat/main.css -o chat/main.css
    curl -s $messages/chat/index.html -o chat/index.html
    curl -s $messages/messages.py -o messages.py
    uvicorn messages:app --host 0.0.0.0 --port 4000 # --log-level critical
    # ----------------- end of edits ------------------
else
    rm start
    curl -s $messages/start -o start
    curl -s $messages/messages.py -o messages.py
    sh start
fi
