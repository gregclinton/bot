repo="https://raw.githubusercontent.com/gregclinton/bot/refs/heads/main"
bot=$repo/bot
chat=$repo/chat
app=$repo/apps/wireless

if [ -f web.py ]; then
    # ---- edits here donls't require a docker build ----
    for name in unique chronological
    do
        curl $bot/$name.py -o $name.py
    done

    curl $chat/messages.py -o messages.py

    mkdir chat
    for file in chat.js main.css index.html
    do
        curl $chat/$file -o chat/$file
    done

    uvicorn web:app --host 0.0.0.0 --port 4000
    # ----------------- end of edits ------------------
else
    rm start
    curl $chat/start -o start
    curl $chat/web.py -o web.py
    sh start
fi
