# cd ~/app
# sh ~/bot/apps/run wireless

source=~/bot
app="$source"/apps/"$1"
boss=Greg

rm -rf messages workers
cp "$source"/bot/*.py .
cp "$app"/tools/* .

for path in "$app"/workers/*
do
    worker=$(basename "$path")
    folder=messages/"$worker"
    mkdir -p "$folder"
    cat "$path" > $folder/"$boss"
done

while true
do
    for path in "$app"/workers/*
    do
        worker=$(basename "$path")
        python3 worker.py groq openai/gpt-oss-120b "$worker"
    done

    for path in "$app"/tools/*
    do
        tool=$(basename "$path")
        python3 tool.py "$tool"
    done

    sleep 1
done