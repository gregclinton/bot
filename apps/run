source=~/bot
apps=$source/apps

for path in $apps/"$1"/workers/*
do
    name="$(basename "$path")"
    curl -s $MESSAGES_URL/"$name" > /dev/null # clear leftover messages
    cat "$path" | sh $apps/post Greg "$name"
done

for path in $apps/"$1"/tools/*
do
    cp $path .
done

cp $source/crm/*.py .
rm -rf workers
ls
exit

while true
do
    for worker in Hal Billing
    do
        python3 worker.py groq openai/gpt-oss-120b "$worker"
    done

    for tool in Balance Enroll
    do
        python3 tool.py "$tool"
    done

    sleep 1
done