# cd ~/app
# sh ~/bot/apps/run wireless

source=~/bot
app="$source"/apps/"$1"

for path in "$app"/workers/*
do
    worker=$(basename "$path")
    curl -s "$MESSAGES_URL/$worker" > /dev/null # clear leftover messages
    cat "$path" | sh "$source"/messages/post Greg $worker
done

cp "$source"/crm/*.py .
cp "$app"/tools/* .
rm -rf workers

while true
do
    for path in "$app"/workers/*
    do
        worker=$(basename "$path")
        python3 worker.py groq openai/gpt-oss-120b "$worker"
    done

    for path in "$app"/tools/*
    do
        tool=$(basename "$path")
        python3 tool.py "$tool"
    done

    sleep 1
done