# cd ~/app
# sh ~/bot/apps/run wireless

source=~/bot
app="$source"/apps/"$1"
boss=Greg

rm -rf messages workers
cp "$source"/bot/*.py .
cp "$app"/tools/* .

for path in "$app"/workers/*
do
    worker=$(basename "$path")
    folder=messages/"$worker"
    mkdir -p "$folder"
    cat "$path" > $folder/"$boss"
    echo "From: $boss"
    echo "To: $worker"
    cat "$path"
    printf "\n\n---------------------------\n\n"
done

stty -icanon min 0 time 0
while true
do
    for path in "$app"/workers/*
    do
        worker=$(basename "$path")
        python3 worker.py groq openai/gpt-oss-120b "$worker"
    done

    for path in "$app"/tools/*
    do
        tool=$(basename "$path")
        python3 tool.py "$tool"
    done

    c=$(dd bs=1 count=1 2>/dev/null)
    [ -n "$c" ] && break
    sleep 1
done