for path in ~/bot/apps/"$1"/workers/*
do
    name="$(basename "$path")"
    echo $name
    curl -s $MESSAGES_URL/"$name" > /dev/null # clear leftover messages
    cat "$path" | sh ~/bot/apps/post Above "$name"
done
exit

rm -rf workers

while true
do
    for worker in Hal Billing
    do
        python3 worker.py groq openai/gpt-oss-120b "$worker"
    done

    for tool in Balance Enroll
    do
        python3 tool.py "$tool"
    done

    sleep 1
done