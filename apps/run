# cd ~/app
# sh ~/bot/apps/run wireless

source=~/bot
app="$source"/apps/"$1"
boss=Greg

rm -r * && cp "$source"/bot/* . && cp "$app"/tools/* .

for path in "$app"/workers/*
do
    worker=$(basename "$path")
    # call messages.post
    python3 messages.py "$boss" "$worker" "$(cat "$path")" 
done

while true
do
    for path in "$app"/workers/*
    do
        worker=$(basename "$path")
        python3 worker.py groq openai/gpt-oss-120b "$worker"
    done

    for path in "$app"/tools/*
    do
        tool=$(basename "$path")
        python3 tool.py "$tool"
    done

    sleep 0.1
done
