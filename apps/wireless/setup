# cd ~/app
# sh ~/bot/apps/wireless/setup

source=~/bot
cp $source/bot/* .
app=$source/apps/"$(basename $(dirname "$0"))"

rm -rf workers

for path in "$app"/workers/*
do
    worker=$(basename "$path")
    dst=workers/"$worker"/instructions
    mkdir -p "$dst"
    cp "$path" "$dst"/"1773019154|HR|""$worker"
done