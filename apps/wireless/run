source=~/bot
cp $source/bot/* .
app=$source/apps/"$(basename $(dirname "$0"))"
cp "$app"/tools/* .

while true
do
    for worker in Hal Billing Sales
    do
        python3 worker.py groq openai/gpt-oss-120b "$worker"
    done

    for tool in Balance
    do
        python3 tool.py "$tool"
    done

    sleep 0.1
done