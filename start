if [ -f Dockerfile ]; then
    rm Dockerfile
    # ---- edits here donls't require a docker build ----
    mv messages/*.py .
    rm -rf apps crm messages
    rm README.md setup start
    uvicorn web:app --host 0.0.0.0 --port 4000
    # ----------------- end of edits ------------------
else
    rm start
    curl -sL https://github.com/gregclinton/bot/archive/refs/heads/main.zip -o bot.zip
