repository="https://raw.githubusercontent.com/gregclinton/bot/refs/heads/main"

if [ -f web.py ]; then
    # ---- edits here donls't require a docker build ----
    mkdir chat
    curl -s $repository/chat/chat.js -o chat/chat.js
    curl -s $repository/chat/main.css -o chat/main.css
    curl -s $repository/chat/index.html -o chat/index.html

    curl -s $repository/bot/llm.py -o llm.py
    curl -s $repository/bot/messages.py -o messages.py
    curl -s $repository/bot/tool.py -o tool.py
    curl -s $repository/bot/worker.py -o worker.py

    uvicorn web:app --host 0.0.0.0 --port 4000 --log-level critical
    # ----------------- end of edits ------------------
else
    rm start
    curl -s $repository/start -o start
    curl -s $repository/web.py -o web.py
    sh start
fi
