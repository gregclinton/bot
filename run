export MESSAGES_URL=https://"$RUNPOD_POD_ID"-4000.proxy.runpod.net/messages

for name in Hal Billing Balance CX143623
do
    curl -s $MESSAGES_URL/"$name" > /dev/null # clear straggler messages
done

rm -rf workers

sh post Above Hal     "$(cat ~/bot/apps/wireless/workers/Hal)"
sh post Above Billing "$(cat ~/bot/apps/wireless/workers/Billing)"

while true
do
    for worker in Hal Billing
    do
        python3 worker.py groq openai/gpt-oss-120b Above "$worker"
    done

    for tool in balance
    do
        python3 $tool.py
    done
    sleep 1
done